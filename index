<script>
/* ---- SLIDER ---- */
let currentSlide = 0;
const slides = document.querySelectorAll('.hero-slide');
const dots = document.querySelectorAll('.slider-dot');
const progressBar = document.getElementById('progressBar');
const SLIDE_DURATION = 5000;
let autoPlay;

function showSlide(n) {
  slides[currentSlide].classList.remove('active');
  dots[currentSlide].classList.remove('active');
  currentSlide = (n + slides.length) % slides.length;
  slides[currentSlide].classList.add('active');
  dots[currentSlide].classList.add('active');
  resetProgress();
}
function changeSlide(dir) { showSlide(currentSlide + dir); resetAutoPlay(); }
function goToSlide(n) { showSlide(n); resetAutoPlay(); }
function resetProgress() {
  progressBar.style.transition = 'none';
  progressBar.style.width = '0%';
  setTimeout(function() {
    progressBar.style.transition = 'width ' + SLIDE_DURATION + 'ms linear';
    progressBar.style.width = '100%';
  }, 50);
}
function resetAutoPlay() {
  clearInterval(autoPlay);
  autoPlay = setInterval(function() { showSlide(currentSlide + 1); }, SLIDE_DURATION);
}
resetAutoPlay();
resetProgress();

/* ---- FAQ ---- */
function toggleFaq(el) {
  el.classList.toggle('open');
  el.nextElementSibling.classList.toggle('open');
}

/* ---- EXPRESS DAY WARNING ---- */
function checkExpressDay(select) {
  var regularDays = ['Mardi', 'Jeudi', 'Dimanche'];
  var warning = document.getElementById('expressDayWarning');
  if (regularDays.indexOf(select.value) === -1 && select.value !== '') {
    warning.style.display = 'block';
  } else {
    warning.style.display = 'none';
  }
}

/* ---- FORM --> WHATSAPP ---- */
function submitForm(e) {
  e.preventDefault();
  var name    = document.getElementById('f-name').value.trim();
  var tel     = document.getElementById('f-tel').value.trim();
  var addr    = document.getElementById('f-addr').value.trim();
  var service = document.getElementById('f-service').value;
  var day     = document.getElementById('f-day').value;
  var details = document.getElementById('f-details').value.trim();

  if (!name || !tel || !addr || !service || !day) {
    alert('Veuillez remplir tous les champs obligatoires.');
    return;
  }

  var msg = '*Nouvelle commande Bolo Pressing*\n\n'
    + '*Nom :* ' + name + '\n'
    + '*T\u00e9l\u00e9phone :* ' + tel + '\n'
    + '*Adresse :* ' + addr + '\n'
    + '*Service :* ' + service + '\n'
    + '*Jour souhait\u00e9 :* ' + day + '\n'
    + (details ? '*D\u00e9tails :* ' + details : '');

  var waUrl = 'https://wa.me/22378119715?text=' + encodeURIComponent(msg);
  window.open(waUrl, '_blank');
}
</script>
